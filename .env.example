# ── Database ───────────────────────────────────────────────────────────────────
# Standard PostgreSQL connection string.
# For Docker Compose, use: postgres://zatca:zatca@db:5432/zatca
# For Neon (Replit), paste your Neon connection string here.
DATABASE_URL=postgres://zatca:zatca@localhost:5432/zatca

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── AI Provider ────────────────────────────────────────────────────────────────
# Choose which AI backend to use: "claude" or "ragflow"
AI_PROVIDER=claude

# ── Claude API (AI_PROVIDER=claude) ───────────────────────────────────────────
# Your Anthropic API key. Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key-here
# Optional: override the model (default: claude-sonnet-4-6)
CLAUDE_MODEL=claude-sonnet-4-6
# Optional: override the Anthropic base URL (leave blank for default)
ANTHROPIC_BASE_URL=

# ── RAGFlow Gateway (AI_PROVIDER=ragflow) ─────────────────────────────────────
# Base URL of your RAGFlow gateway (exposes POST /agent/run)
RAGFLOW_BASE_URL=http://localhost:8000
# Optional: Bearer token for the gateway
RAGFLOW_API_KEY=your-ragflow-api-key-here
# Agent name to call. Available agents:
#   ndmo-classification | pii-detection | business-definitions |
#   report-tester | dq-rules-generator
RAGFLOW_AGENT=dq-rules-generator
