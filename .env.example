# ── Database ───────────────────────────────────────────────────────────────────
# Standard PostgreSQL connection string.
# For Docker Compose, use: postgres://zatca:zatca@db:5432/zatca
# For Neon (Replit), paste your Neon connection string here.
DATABASE_URL=postgres://zatca:zatca@localhost:5432/zatca

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── AI Provider ────────────────────────────────────────────────────────────────
# Choose which AI backend to use: "claude" or "ragflow"
AI_PROVIDER=claude

# ── Claude API (AI_PROVIDER=claude) ───────────────────────────────────────────
# Your Anthropic API key. Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key-here
# Optional: override the model (default: claude-sonnet-4-6)
CLAUDE_MODEL=claude-sonnet-4-6
# Optional: override the Anthropic base URL (leave blank for default)
ANTHROPIC_BASE_URL=

# ── RAGFlow Native API (AI_PROVIDER=ragflow) ──────────────────────────────────
# Base URL of your RAGFlow instance (uses /api/v1/agents/* endpoints directly)
RAGFLOW_BASE_URL=http://localhost:80
# RAGFlow API key (sent as Bearer token)
RAGFLOW_API_KEY=your-ragflow-api-key-here
# Default agent display name (used when no per-request override is provided)
# Available: DNA-Agent-SuperVisor | DQ-Rules-Generator | Business-Definitions |
#            PII-Detection | Report-Tester | NDMO-Data-Classification
RAGFLOW_AGENT=DNA-Agent-SuperVisor
